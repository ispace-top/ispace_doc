# i·Space Doc Docker 环境变量配置模板
# 复制此文件为 .env 并修改各配置项

# ============================================================
# 必填项
# ============================================================

# Django SECRET_KEY（必填，建议使用以下命令生成）
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# PostgreSQL 数据库密码（完整模式必填，轻量模式不需要）
DB_PASSWORD=

# ============================================================
# 可选项（以下为默认值）
# ============================================================

# 数据库配置
# DB_NAME=ispace
# DB_USER=ispace

# Debug 模式（生产环境务必设为 false）
# DEBUG=false
